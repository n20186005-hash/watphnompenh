---
import { mapsUrl } from '../config';

interface Props { lang: string; messages: any; t: (k: string) => string; }
const { messages: m } = Astro.props;
const s = m.gallery;

const spans = ['gallery-span-2', 'gallery-span-1', 'gallery-span-1', 'gallery-span-1', 'gallery-span-1', 'gallery-span-3', 'gallery-span-1', 'gallery-span-1', 'gallery-span-1', 'gallery-span-1', 'gallery-span-3', 'gallery-span-1'];
---
<section id="gallery" class="section-padding">
  <div class="container">
    <p class="eyebrow">{s.eyebrow}</p>
    <h2 class="section-title">{s.title}</h2>
    <p class="section-lead">{s.subtitle}</p>

    <div class="gallery-grid">
      {s.photos.map((p: any, i: number) => (
        <figure class={`gallery-item ${spans[i % spans.length]}`}>
          <img src={p.src} alt={p.alt} loading="lazy" />
          <figcaption class="cap">{p.caption}</figcaption>
        </figure>
      ))}
    </div>

    <div class="gallery-cta">
      <a class="link-accent" href={mapsUrl} target="_blank" rel="noopener">↗ {s.viewMaps}</a>
    </div>
  </div>
</section>

<style>
  .gallery-cta { margin-top: 22px; text-align: center; }
</style>
