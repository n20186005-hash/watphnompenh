---
import AudioGuide from './AudioGuide.astro';
interface Props { lang: string; messages: any; t: (k: string) => string; }
const { messages: m } = Astro.props;
const s = m.history;
const a = m.audioGuide;
---
<section id="history" class="section-padding history-section">
  <div class="container">
    <p class="eyebrow">{s.eyebrow}</p>
    <h2 class="section-title">{s.title}</h2>
    <p class="section-lead">{s.subtitle}</p>

    <div class="timeline">
      {s.sections.map((sec: any) => (
        <div class="tl-item">
          <div class="tl-marker"><span>{sec.no}</span></div>
          <div class="tl-content card card-pad">
            <span class="tl-era">{sec.era}</span>
            <h3>{sec.heading}</h3>
            <p>{sec.body}</p>
          </div>
        </div>
      ))}
    </div>

    {s.legendTitle ? (
      <div class="legend-card">
        <span class="legend-badge">{s.legendBadge}</span>
        <h3>{s.legendTitle}</h3>
        <p>{s.legendText}</p>
      </div>
    ) : null}

    <AudioGuide
      badge={a.badge}
      title={a.legendTitle}
      text={a.legendText}
      playLabel={a.play}
      comingSoon={a.comingSoon}
    />
  </div>
</section>

<style>
  .history-section { background: var(--surface-accent); }
  .timeline { margin-top: 36px; display: grid; gap: 22px; position: relative; }
  .tl-item { display: grid; grid-template-columns: 64px 1fr; gap: 18px; align-items: start; }
  .tl-marker { width: 54px; height: 54px; border-radius: 50%; background: var(--accent); color: #fff; display: grid; place-items: center; font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; box-shadow: var(--shadow-md); position: relative; z-index: 2; }
  .tl-content { margin: 0; }
  .tl-era { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-strong); font-weight: 700; }
  .tl-content h3 { margin: 6px 0 8px; font-size: 1.25rem; }
  .tl-content p { margin: 0; color: var(--text-muted); }
  .legend-card { margin-top: 32px; background: var(--surface); border: 1px solid var(--border); border-left: 4px solid var(--accent); border-radius: var(--radius); padding: 26px 30px; box-shadow: var(--shadow-sm); }
  .legend-badge { display: inline-block; font-size: 0.74rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-strong); font-weight: 700; margin-bottom: 8px; }
  .legend-card h3 { margin: 0 0 10px; font-size: 1.4rem; }
  .legend-card p { margin: 0; color: var(--text-muted); }
  @media (max-width: 600px) { .tl-item { grid-template-columns: 44px 1fr; gap: 12px; } .tl-marker { width: 42px; height: 42px; font-size: 1rem; } }
</style>
