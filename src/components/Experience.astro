---
import Icon from './Icon.astro';
interface Props { lang: string; messages: any; t: (k: string) => string; }
const { messages: m } = Astro.props;
const s = m.experience;
---
<section id="experience" class="section-padding">
  <div class="container">
    <p class="eyebrow">{s.eyebrow}</p>
    <h2 class="section-title">{s.title}</h2>
    <p class="section-lead">{s.subtitle}</p>

    <div class="exp-grid">
      {s.items.map((it: any) => (
        <div class="card card-pad exp-card">
          <div class="exp-ico"><Icon name={it.icon} /></div>
          <h3>{it.title}</h3>
          <p>{it.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-grid { margin-top: 32px; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; }
  .exp-card { transition: transform 0.2s ease, box-shadow 0.2s ease; border-top: 3px solid var(--accent); }
  .exp-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .exp-ico { width: 50px; height: 50px; border-radius: 13px; background: var(--accent-soft); color: var(--accent-strong); display: grid; place-items: center; margin-bottom: 14px; }
  .exp-card h3 { margin: 0 0 8px; font-size: 1.25rem; }
  .exp-card p { margin: 0; color: var(--text-muted); }
</style>
