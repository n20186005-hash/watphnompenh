---
interface Props {
  badge: string;
  title: string;
  text: string;
  playLabel?: string;
  comingSoon?: string;
}
const { badge, title, text, playLabel = 'Play', comingSoon = 'Audio coming soon' } = Astro.props;
---
<div class="audio-guide">
  <span class="ag-badge">{badge}</span>
  <div class="ag-body">
    <h4 class="ag-title">{title}</h4>
    <p class="ag-text">{text}</p>
  </div>
  <div class="ag-action">
    <button class="ag-play" type="button" disabled aria-label={playLabel}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
      <span>{playLabel}</span>
    </button>
    <span class="ag-soon">{comingSoon}</span>
  </div>
</div>
