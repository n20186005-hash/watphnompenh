---
import { languagesList, languages } from '../i18n/ui';
import { mapsUrl } from '../config';

interface Props {
  lang: string;
  messages: any;
  t: (k: string) => string;
}
const { lang, messages: m, t } = Astro.props;

const navGroups = [
  { key: 'navAbout', items: [
    { id: 'intro', label: m.header.intro },
    { id: 'history', label: m.header.history },
    { id: 'architecture', label: m.header.architecture },
  ]},
  { key: 'navGuide', items: [
    { id: 'best-time', label: m.header.bestTime },
    { id: 'experience', label: m.header.experience },
    { id: 'practical', label: m.header.practical },
    { id: 'faq', label: m.header.faq },
  ]},
  { key: 'navTransit', items: [
    { id: 'transport', label: m.header.transport },
    { id: 'map', label: m.header.map },
  ]},
  { key: 'navExplore', items: [
    { id: 'nearby', label: m.header.nearby },
    { id: 'food', label: m.header.food },
  ]},
];

function switchUrl(l: string): string {
  const parts = Astro.url.pathname.split('/').filter(Boolean).slice(1); // drop lang
  const rest = parts.join('/');
  return `/${l}${rest ? '/' + rest : ''}`;
}
---
<header class="site-header">
  <div class="container header-inner">
    <a href={`/${lang}`} class="brand">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 4v6c0 4-3 6-7 8-4-2-7-4-7-8V7l7-4z"/><path d="M12 7v10"/><path d="M9 11h6"/></svg>
      </span>
      <span class="brand-text">{m.header.siteName}</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {navGroups.map((g) => (
        <div class="nav-group">
          <button class="nav-group-label" type="button" aria-haspopup="true" aria-expanded="false">
            {m.header[g.key]}
            <span class="caret" aria-hidden="true"></span>
          </button>
          <div class="nav-dropdown">
            {g.items.map((item) => (
              <a href={`/${lang}#${item.id}`}>{item.label}</a>
            ))}
          </div>
        </div>
      ))}
    </nav>

    <div class="header-actions">
      <a class="header-maps" href={mapsUrl} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {t('common.maps')}
      </a>

      <button class="icon-btn" data-theme-toggle aria-label="Toggle theme">
        <svg class="ic-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="ic-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
      </button>

      <div class="lang-switch">
        {languagesList.map((l) => (
          <a href={switchUrl(l)} class={`lang-opt ${l === lang ? 'active' : ''}`} hreflang={l}>{languages[l]}</a>
        ))}
      </div>

      <button class="icon-btn menu-btn" data-menu-btn aria-label="Menu">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" data-menu aria-label="Mobile">
    <div class="container">
      {navGroups.map((g) => (
        <div class="mobile-group">
          <p class="mobile-group-label">{m.header[g.key]}</p>
          {g.items.map((item) => (
            <a href={`/${lang}#${item.id}`}>{item.label}</a>
          ))}
        </div>
      ))}
      <div class="mobile-langs">
        {languagesList.map((l) => (
          <a href={switchUrl(l)} class={`lang-opt ${l === lang ? 'active' : ''}`}>{languages[l]}</a>
        ))}
      </div>
    </div>
  </nav>
</header>
