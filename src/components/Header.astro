---
import { languagesList, languages } from '../i18n/ui';
import { mapsUrl } from '../config';

interface Props {
  lang: string;
  messages: any;
  t: (k: string) => string;
}
const { lang, messages: m, t } = Astro.props;

const nav = [
  { id: 'intro', label: m.header.intro },
  { id: 'history', label: m.header.history },
  { id: 'architecture', label: m.header.architecture },
  { id: 'experience', label: m.header.experience },
  { id: 'best-time', label: m.header.bestTime },
  { id: 'transport', label: m.header.transport },
  { id: 'map', label: m.header.map },
  { id: 'nearby', label: m.header.nearby },
  { id: 'food', label: m.header.food },
  { id: 'practical', label: m.header.practical },
  { id: 'faq', label: m.header.faq },
];

function switchUrl(l: string): string {
  const parts = Astro.url.pathname.split('/').filter(Boolean).slice(1); // drop lang
  const rest = parts.join('/');
  return `/${l}${rest ? '/' + rest : ''}`;
}
---
<header class="site-header">
  <div class="container header-inner">
    <a href={`/${lang}`} class="brand">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 4v6c0 4-3 6-7 8-4-2-7-4-7-8V7l7-4z"/><path d="M12 7v10"/><path d="M9 11h6"/></svg>
      </span>
      <span class="brand-text">{m.header.siteName}</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {nav.map((item) => (
        <a href={`/${lang}#${item.id}`}>{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="header-maps" href={mapsUrl} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {t('common.maps')}
      </a>

      <button class="icon-btn" data-theme-toggle aria-label="Toggle theme">
        <svg class="ic-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="ic-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
      </button>

      <div class="lang-switch">
        {languagesList.map((l) => (
          <a href={switchUrl(l)} class={`lang-opt ${l === lang ? 'active' : ''}`} hreflang={l}>{languages[l]}</a>
        ))}
      </div>

      <button class="icon-btn menu-btn" data-menu-btn aria-label="Menu">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" data-menu aria-label="Mobile">
    <div class="container">
      {nav.map((item) => (
        <a href={`/${lang}#${item.id}`}>{item.label}</a>
      ))}
      <div class="mobile-langs">
        {languagesList.map((l) => (
          <a href={switchUrl(l)} class={`lang-opt ${l === lang ? 'active' : ''}`}>{languages[l]}</a>
        ))}
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(1.2) blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 18px;
    height: 66px;
  }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-weight: 700; color: var(--heading); font-size: 1.05rem; }
  .brand-mark { width: 34px; height: 34px; border-radius: 10px; display: grid; place-items: center; background: var(--accent); color: #fff; flex: none; }
  .nav-desktop { display: flex; gap: 4px; margin-left: 8px; flex: 1; flex-wrap: wrap; }
  .nav-desktop a { padding: 8px 11px; border-radius: 8px; font-size: 0.9rem; color: var(--text-muted); transition: color 0.15s, background 0.15s; }
  .nav-desktop a:hover { color: var(--heading); background: var(--surface-2); }
  .header-actions { display: flex; align-items: center; gap: 10px; }
  .header-maps { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 999px; background: var(--accent-soft); color: var(--accent-strong); font-weight: 600; font-size: 0.88rem; }
  .header-maps:hover { background: var(--border-strong); color: #fff; }
  .icon-btn { width: 38px; height: 38px; border-radius: 10px; border: 1px solid var(--border); background: var(--surface); color: var(--text); display: grid; place-items: center; cursor: pointer; }
  .icon-btn:hover { background: var(--surface-2); }
  .lang-switch { display: flex; gap: 2px; background: var(--surface-2); border-radius: 999px; padding: 3px; }
  .lang-opt { padding: 6px 11px; border-radius: 999px; font-size: 0.84rem; font-weight: 600; color: var(--text-muted); }
  .lang-opt.active { background: var(--accent); color: #fff; }
  .menu-btn { display: none; }
  .ic-moon { display: none; }
  :global(html[data-theme='dark']) .ic-sun { display: none; }
  :global(html[data-theme='dark']) .ic-moon { display: block; }

  .nav-mobile { display: none; border-top: 1px solid var(--border); background: var(--surface); }
  .nav-mobile.open { display: block; }
  .nav-mobile .container { display: flex; flex-direction: column; padding-block: 10px; }
  .nav-mobile a { padding: 11px 8px; border-radius: 8px; color: var(--text); }
  .nav-mobile a:hover { background: var(--surface-2); }
  .mobile-langs { display: flex; gap: 6px; margin-top: 8px; }
  .mobile-langs .lang-opt { background: var(--surface-2); }

  @media (max-width: 1080px) {
    .nav-desktop { display: none; }
    .menu-btn { display: grid; }
    .header-maps { display: none; }
  }
</style>
