---
import { mapsUrl, mapsEmbedSrc } from '../config';

interface Props { lang: string; messages: any; t: (k: string) => string; }
const { messages: m } = Astro.props;
const s = m.map;
---
<section id="map" class="section-padding map-section">
  <div class="container">
    <p class="eyebrow">{s.eyebrow}</p>
    <h2 class="section-title">{s.title}</h2>
    <p class="section-lead">{s.subtitle}</p>

    <div class="map-layout">
      <div class="map-info card card-pad">
        <div class="map-info-row">
          <span class="map-info-label">{s.addressLabel}</span>
          <span class="map-info-value">{s.addressValue}</span>
        </div>
        <div class="map-info-row">
          <span class="map-info-label">{s.hoursLabel}</span>
          <span class="map-info-value">{s.hoursValue}</span>
        </div>
        <a class="btn-cta btn-cta-primary map-open" href={mapsUrl} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {s.openLabel}
        </a>
      </div>

      <div class="map-container">
        <iframe src={mapsEmbedSrc} title={s.title} loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .map-section { background: var(--surface-accent); }
  .map-layout { margin-top: 30px; display: grid; grid-template-columns: 340px 1fr; gap: 22px; align-items: stretch; }
  .map-info { display: flex; flex-direction: column; gap: 16px; }
  .map-info-row { display: flex; flex-direction: column; gap: 4px; padding-bottom: 14px; border-bottom: 1px solid var(--border); }
  .map-info-label { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-strong); font-weight: 700; }
  .map-info-value { color: var(--heading); font-weight: 600; }
  .map-open { margin-top: auto; }
  @media (max-width: 820px) { .map-layout { grid-template-columns: 1fr; } .map-container { aspect-ratio: 4 / 3; } }
</style>
