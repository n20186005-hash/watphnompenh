---
import '../styles/global.css';
import { getI18n, buildAlternates, htmlLangAttr } from '../i18n/ui';
import siteConfig, { mapsUrl, attraction } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { pathname } = Astro.url;
const { lang, messages, t } = getI18n(Astro.url);
const alt = buildAlternates();

const props = Astro.props as {
  title?: string;
  description?: string;
  image?: string;
  path?: string;
  type?: string;
};

const SITE = siteConfig.baseUrl;
const pageUrl = `${SITE}/${lang}${props.path ?? ''}`;
const title = props.title ?? messages.meta.title;
const description = props.description ?? messages.meta.description;
const image = props.image ?? `${SITE}/gallery/wat-phnom-daun-penh-1.jpg`;
const localeMap: Record<string, string> = { km: 'km_KH', en: 'en_US', zh: 'zh_CN' };

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: attraction.name.en,
  alternateName: [attraction.name.km, attraction.name.zh],
  description,
  image: [`${SITE}/gallery/wat-phnom-daun-penh-1.jpg`, `${SITE}/gallery/wat-phnom-daun-penh-2.jpg`, `${SITE}/gallery/wat-phnom-daun-penh-3.jpg`],
  url: pageUrl,
  sameAs: [mapsUrl],
  touristType: 'Cultural tourism, Religious tourism, Photography',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Wat Phnom Road',
    addressLocality: 'Phnom Penh',
    addressCountry: 'KH',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: attraction.lat,
    longitude: attraction.lng,
  },
  openingHours: 'Mo-Su 07:00-19:00',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '07:00',
      closes: '19:00',
    },
  ],
  publicAccess: true,
  isAccessibleForFree: true,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: attraction.rating,
    reviewCount: attraction.reviews,
  },
  isPartOf: { '@type': 'TouristDestination', name: 'Phnom Penh', address: { '@type': 'PostalAddress', addressLocality: 'Phnom Penh', addressCountry: 'KH' } },
};
---
<!doctype html>
<html lang={htmlLangAttr(lang)} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#b8862c" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={attraction.name.en} />
    <meta property="og:locale" content={localeMap[lang] ?? 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    {Object.entries(alt).map(([k, v]) => (
      <link rel="alternate" hreflang={k === 'xDefault' ? 'x-default' : k} href={v} />
    ))}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          if (saved) document.documentElement.setAttribute('data-theme', saved);
          else if (window.matchMedia('(prefers-color-scheme: dark)').matches) document.documentElement.setAttribute('data-theme', 'dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} messages={messages} t={t} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} messages={messages} t={t} />

    <script is:inline>
      // Theme toggle
      document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var root = document.documentElement;
          var cur = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
          var next = cur === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      });
      // Mobile menu
      var mb = document.querySelector('[data-menu-btn]');
      var mn = document.querySelector('[data-menu]');
      if (mb && mn) {
        mb.addEventListener('click', function () { mn.classList.toggle('open'); });
        mn.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', function () { mn.classList.remove('open'); }); });
      }
      // FAQ accordion
      document.querySelectorAll('.faq-item').forEach(function (item) {
        var q = item.querySelector('.faq-q');
        if (!q) return;
        q.addEventListener('click', function () {
          var open = item.getAttribute('data-open') === 'true';
          item.setAttribute('data-open', open ? 'false' : 'true');
          var a = item.querySelector('.faq-a');
          if (a) a.style.maxHeight = open ? '0px' : a.scrollHeight + 'px';
        });
      });
      // Reveal on scroll
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.12 });
      document.querySelectorAll('.fade-up').forEach(function (el) { io.observe(el); });
      // Lightbox
      var lb;
      function openLightbox(src, alt) {
        lb = document.createElement('div');
        lb.className = 'lightbox';
        lb.innerHTML = '<button class="lb-close" aria-label="Close">&times;</button><button class="lb-nav lb-prev" aria-label="Previous">&#8249;</button><button class="lb-nav lb-next" aria-label="Next">&#8250;</button><img src="' + src + '" alt="' + (alt || '') + '">';
        document.body.appendChild(lb);
        document.body.style.overflow = 'hidden';
        var items = Array.from(document.querySelectorAll('.gallery-item img'));
        var idx = items.findIndex(function (i) { return i.getAttribute('src') === src; });
        function show(i) {
          idx = (i + items.length) % items.length;
          lb.querySelector('img').src = items[idx].getAttribute('src');
          lb.querySelector('img').alt = items[idx].alt || '';
        }
        lb.querySelector('.lb-close').onclick = closeLightbox;
        lb.querySelector('.lb-prev').onclick = function () { show(idx - 1); };
        lb.querySelector('.lb-next').onclick = function () { show(idx + 1); };
        lb.onclick = function (e) { if (e.target === lb) closeLightbox(); };
        document.addEventListener('keydown', function esc(e) {
          if (e.key === 'Escape') closeLightbox();
          if (e.key === 'ArrowLeft') show(idx - 1);
          if (e.key === 'ArrowRight') show(idx + 1);
          if (e.type === 'keydown' && (e.key === 'Escape' || e.key === 'ArrowLeft' || e.key === 'ArrowRight')) {
            document.removeEventListener('keydown', esc);
          }
        });
      }
      function closeLightbox() { if (lb) { lb.remove(); lb = null; document.body.style.overflow = ''; } }
      document.querySelectorAll('.gallery-item').forEach(function (g) {
        g.addEventListener('click', function () { var im = g.querySelector('img'); openLightbox(im.getAttribute('src'), im.alt); });
      });
    </script>
  </body>
</html>
