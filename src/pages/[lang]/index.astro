---
import { getI18n } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Intro from '../../components/Intro.astro';
import History from '../../components/History.astro';
import Architecture from '../../components/Architecture.astro';
import Gallery from '../../components/Gallery.astro';
import Experience from '../../components/Experience.astro';
import BestTime from '../../components/BestTime.astro';
import Transport from '../../components/Transport.astro';
import Amenities from '../../components/Amenities.astro';
import MapSection from '../../components/MapSection.astro';
import Nearby from '../../components/Nearby.astro';
import Food from '../../components/Food.astro';
import Practical from '../../components/Practical.astro';
import Etiquette from '../../components/Etiquette.astro';
import FAQ from '../../components/FAQ.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'km' } },
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}

const { lang, messages: m, t } = getI18n(Astro.url);
const title = m.meta.title;
const description = m.meta.description;
---
<BaseLayout title={title} description={description}>
  <Hero lang={lang} messages={m} t={t} />
  <Intro lang={lang} messages={m} t={t} />
  <History lang={lang} messages={m} t={t} />
  <Architecture lang={lang} messages={m} t={t} />
  <Gallery lang={lang} messages={m} t={t} />
  <Experience lang={lang} messages={m} t={t} />
  <BestTime lang={lang} messages={m} t={t} />
  <Transport lang={lang} messages={m} t={t} />
  <Amenities lang={lang} messages={m} t={t} />
  <MapSection lang={lang} messages={m} t={t} />
  <Nearby lang={lang} messages={m} t={t} />
  <Food lang={lang} messages={m} t={t} />
  <Practical lang={lang} messages={m} t={t} />
  <Etiquette lang={lang} m={m} />
  <FAQ lang={lang} messages={m} t={t} />
</BaseLayout>
